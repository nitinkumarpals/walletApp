# Frontend environment (copy to .env.local for local dev).
# Only NEXT_PUBLIC_* vars are used — they are exposed to the browser, so put
# NO secrets here. All real secrets live in the backend (application-local.yml).

# Base URL of the Spring backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Razorpay PUBLIC key id (safe to expose; used to open Razorpay Checkout).
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-public-key-id
